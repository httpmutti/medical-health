# ── App ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/skin_firts_db

# ── JWT ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_token_secret_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── PostHog ─────────────────────────────────────────────────────
POSTHOG_API_KEY=phc_your_posthog_key
POSTHOG_HOST=https://app.posthog.com

# ── OTP ─────────────────────────────────────────────────────────
OTP_TTL_SECONDS=600
OTP_LENGTH=6

# ── Rate limiting ───────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=10
