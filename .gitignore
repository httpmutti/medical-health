# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Environment variables (never commit real secrets) ────────────────
.env
.env.local
.env.*.local
backend/.env
backend/.env.local

# ── Dependencies ─────────────────────────────────────────────────────
node_modules/
backend/node_modules/

# ── Expo ─────────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ── NestJS build output ───────────────────────────────────────────────
backend/dist/

# ── Native generated folders ──────────────────────────────────────────
/ios
/android
.kotlin/

# ── Native secrets / certs ────────────────────────────────────────────
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ── Metro ─────────────────────────────────────────────────────────────
.metro-health-check*

# ── Debug logs ────────────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*

# ── TypeScript build info ─────────────────────────────────────────────
*.tsbuildinfo
backend/*.tsbuildinfo

# ── macOS ─────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Prisma ────────────────────────────────────────────────────────────
backend/prisma/*.db
backend/prisma/*.db-journal
